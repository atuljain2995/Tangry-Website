# Copy to `.env.local` and fill in values. Never commit real secrets.

# Supabase (required for DB, newsletter, checkout)
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Marketplace “Buy online” — optional. If unset, Flipkart opens a search for “tangry spices”.
# NEXT_PUBLIC_TANGRY_FLIPKART_URL=https://www.flipkart.com/...

# Public Instagram profile URL (optional). Defaults to https://www.instagram.com/tangryspices
# Set this to your live brand handle before launch if it differs.
# NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/yourhandle

# Google Analytics 4 Measurement ID (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
